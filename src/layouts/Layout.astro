---
interface Props {
  title: string;
  currentPage?: string;
}

const { title, currentPage = '' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Chan Nirak Choun — MS Computer Science student and aspiring ML Compiler Engineer." />
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <div class="nav-inner">
        <a href="/" class="nav-name">Chan Nirak Choun</a>
        <ul class="nav-links">
          <li><a href="/" class={currentPage === 'home' ? 'active' : ''}>Home</a></li>
          <li><a href="/projects" class={currentPage === 'projects' ? 'active' : ''}>Projects</a></li>
          <li><a href="/publications" class={currentPage === 'publications' ? 'active' : ''}>Publications</a></li>
          <li><a href="/courses" class={currentPage === 'courses' ? 'active' : ''}>Courses</a></li>
          <li><a href="/books" class={currentPage === 'books' ? 'active' : ''}>Books</a></li>
          <li><a href="/contact" class={currentPage === 'contact' ? 'active' : ''}>Contact</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      &copy; {new Date().getFullYear()} Chan Nirak Choun
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
