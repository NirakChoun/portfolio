---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Chan Nirak Choun" currentPage="contact">

  <h1>Contact</h1>

  <p class="section-intro">
    Feel free to reach out if you'd like to chat about research, collaboration, or anything CS-related.
    I prefer email or texting over phone calls.
  </p>

  <h2>Email</h2>

  <div class="entry">
    <div class="entry-header">
      <h3>Academic</h3>
    </div>
    <p><a href="mailto:nchoun@ucdavis.edu">nchoun@ucdavis.edu</a></p>
  </div>

  <div class="entry">
    <div class="entry-header">
      <h3>Personal</h3>
    </div>
    <p><a href="mailto:nirakchoun@gmail.com">nirakchoun@gmail.com</a></p>
  </div>

  <h2>Phone</h2>

  <div class="entry">
    <p><a href="tel:+17853428741">(785) 342-8741</a></p>
    <p style="font-size: 0.85rem; margin-top: -0.5rem;">I prefer email or text over calls.</p>
  </div>

  <h2>Send a Message</h2>

  <!--
    HOW TO SET UP FORMSPREE:
    1. Go to https://formspree.io and create a free account
    2. Create a new form and add BOTH emails as recipients:
       - nchoun@ucdavis.edu
       - nirakchoun@gmail.com
    3. Copy your form ID (looks like "xyzabcde")
    4. Replace YOUR_FORM_ID below with your actual ID

    Free tier: 50 submissions/month with built-in spam filtering.
  -->

  <div class="contact-form-wrapper">
    <form
      id="contact-form"
      action="https://formspree.io/f/YOUR_FORM_ID"
      method="POST"
      novalidate
    >
      <!-- Honeypot — hidden from real users, catches bots -->
      <div style="position: absolute; left: -9999px;" aria-hidden="true">
        <label>Don't fill this out
          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
        </label>
      </div>

      <input type="hidden" name="_subject" value="New message from your portfolio" />

      <div class="form-row">
        <div class="form-group">
          <label for="first-name">First Name <span class="required">*</span></label>
          <input
            type="text"
            id="first-name"
            name="firstName"
            required
            autocomplete="given-name"
            placeholder="John"
          />
        </div>
        <div class="form-group">
          <label for="last-name">Last Name <span class="required">*</span></label>
          <input
            type="text"
            id="last-name"
            name="lastName"
            required
            autocomplete="family-name"
            placeholder="Doe"
          />
        </div>
      </div>

      <div class="form-group">
        <label for="email">Email <span class="required">*</span></label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          placeholder="john@example.com"
        />
        <span class="form-error" id="email-error"></span>
      </div>

      <div class="form-group">
        <label for="message">Message <span class="required">*</span></label>
        <textarea
          id="message"
          name="message"
          required
          rows="5"
          placeholder="What would you like to talk about?"
        ></textarea>
      </div>

      <button type="submit" class="form-submit" id="submit-btn">Send Message</button>
      <p class="form-status" id="form-status"></p>
    </form>
  </div>

</Layout>

<style>
  .contact-form-wrapper {
    margin-top: 1rem;
  }

  .form-row {
    display: flex;
    gap: 1rem;
  }

  .form-row .form-group {
    flex: 1;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 0.35rem;
  }

  .required {
    color: #b44;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    font-family: 'Roboto', sans-serif;
    font-size: 0.9rem;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: #fff;
    color: var(--text);
    transition: border-color 0.2s ease;
    outline: none;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--accent);
  }

  .form-group input.input-error,
  .form-group textarea.input-error {
    border-color: #b44;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-error {
    display: block;
    font-size: 0.8rem;
    color: #b44;
    margin-top: 0.3rem;
    min-height: 1.2em;
  }

  .form-submit {
    font-family: 'Roboto', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border: 1px solid var(--accent);
    border-radius: 3px;
    background: transparent;
    color: var(--text);
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .form-submit:hover {
    background-color: var(--text);
    color: var(--bg);
  }

  .form-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .form-status {
    font-size: 0.85rem;
    margin-top: 0.75rem;
  }

  .form-status.success {
    color: #2a7d2a;
  }

  .form-status.error {
    color: #b44;
  }

  @media (max-width: 600px) {
    .form-row {
      flex-direction: column;
      gap: 0;
    }
  }
</style>

<script>
  const DISPOSABLE_DOMAINS = new Set([
    "10minutemail.com","guerrillamail.com","guerrillamail.net","guerrillamail.org",
    "guerrillamailblock.com","grr.la","guerrillamail.de","tempmail.com","temp-mail.org",
    "temp-mail.io","throwaway.email","throwaway.com","mailinator.com","maildrop.cc",
    "dispostable.com","yopmail.com","yopmail.fr","sharklasers.com","guerrillamail.info",
    "spam4.me","trashmail.com","trashmail.me","trashmail.net","trashmail.org",
    "bugmenot.com","mailnesia.com","mailcatch.com","tempail.com","tempr.email",
    "discard.email","discardmail.com","discardmail.de","emailondeck.com",
    "fakeinbox.com","fake-mail.net","getairmail.com","getnada.com","harakirimail.com",
    "jetable.org","mailexpire.com","mailforspam.com","mailhazard.com","mailhazard.us",
    "mailmoat.com","mailnull.com","mailscrap.com","mailshell.com","mailsiphon.com",
    "mailslite.com","mailtemp.info","mailzilla.com","mintemail.com","moakt.com",
    "mohmal.com","meltmail.com","mt2015.com","mytemp.email","mytrashmail.com",
    "nomail.xl.cx","nospam.ze.tc","owlpic.com","proxymail.eu","rcpt.at",
    "reallymymail.com","recode.me","safetymail.info","spambox.us","spamcowboy.com",
    "spamcowboy.net","spamcowboy.org","spamevil.com","spamfree24.com","spamfree24.de",
    "spamfree24.eu","spamfree24.info","spamfree24.net","spamfree24.org","spaml.com",
    "spamoff.de","spamstack.net","tempinbox.com","tempinbox.co.uk","tempomail.fr",
    "temporaryemail.net","temporaryemail.us","temporaryforwarding.com",
    "temporaryinbox.com","thankyou2010.com","trash-mail.at","trash-mail.com",
    "trash2009.com","trashdevil.com","trashdevil.de","trashymail.com","trashymail.net",
    "turual.com","twinmail.de","wegwerfmail.de","wegwerfmail.net","wegwerfmail.org",
    "willselfdestruct.com","wuzup.net","wuzupmail.net","xagloo.com",
    "xemaps.com","xents.com","xoxy.net","yep.it","zehnminutenmail.de",
    "zippymail.info","zoaxe.com","mailnator.com","binkmail.com","bobmail.info",
    "chammy.info","devnullmail.com","eelmail.com","filzmail.com","incognitomail.org",
    "mailblocks.com","spamhereplease.com","spamthisplease.com","superrito.com",
    "tittbit.in","tradermail.info","mailsac.com","burnermail.io","inboxkitten.com",
    "33mail.com","anonaddy.com","simplelogin.co","guerrillamail.biz",
    "crazymailing.com","tempmailo.com","emailfake.com","tempemails.io"
  ]);

  function isDisposableEmail(email) {
    const domain = email.split("@")[1]?.toLowerCase();
    if (!domain) return false;
    return DISPOSABLE_DOMAINS.has(domain);
  }

  function isValidEmailFormat(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email);
  }

  const form = document.getElementById("contact-form");
  const emailInput = document.getElementById("email");
  const emailError = document.getElementById("email-error");
  const submitBtn = document.getElementById("submit-btn");
  const formStatus = document.getElementById("form-status");

  emailInput.addEventListener("blur", () => {
    validateEmail();
  });

  emailInput.addEventListener("input", () => {
    emailInput.classList.remove("input-error");
    emailError.textContent = "";
  });

  function validateEmail() {
    const email = emailInput.value.trim();
    if (!email) {
      emailError.textContent = "";
      return false;
    }
    if (!isValidEmailFormat(email)) {
      emailInput.classList.add("input-error");
      emailError.textContent = "Please enter a valid email address.";
      return false;
    }
    if (isDisposableEmail(email)) {
      emailInput.classList.add("input-error");
      emailError.textContent = "Disposable or temporary email addresses are not accepted.";
      return false;
    }
    emailInput.classList.remove("input-error");
    emailError.textContent = "";
    return true;
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!validateEmail()) {
      emailInput.focus();
      return;
    }

    const firstName = document.getElementById("first-name").value.trim();
    const lastName = document.getElementById("last-name").value.trim();
    const message = document.getElementById("message").value.trim();

    if (!firstName || !lastName || !emailInput.value.trim() || !message) {
      formStatus.textContent = "Please fill in all required fields.";
      formStatus.className = "form-status error";
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Sending...";
    formStatus.textContent = "";

    try {
      const response = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { "Accept": "application/json" },
      });

      if (response.ok) {
        formStatus.textContent = "Message sent! I'll get back to you soon.";
        formStatus.className = "form-status success";
        form.reset();
      } else {
        throw new Error("Submission failed");
      }
    } catch (err) {
      formStatus.textContent = "Something went wrong. Please try emailing me directly.";
      formStatus.className = "form-status error";
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Send Message";
    }
  });
</script>
